# ── weight-keeper: секреты и подключение ───────────────────────────────────
#
# Это ШАБЛОН. На VPS:
#     cp .env.example .env
#     nano .env            # заполнить реальными значениями
#     chmod 600 .env
#
# Файл .env в .gitignore и НИКОГДА не коммитится. Репозиторий остаётся чистым.

# Адрес твоего ntfy-сервера (со схемой, без слэша в конце)
NTFY_URL=https://ntfy.example.com

# Пользователь ntfy под бота (read-only на _in, write-only на _out)
NTFY_USER=bot
NTFY_PASS=сюда_пароль_бота

# Топики: вход (ты -> бот) и выход (бот -> ты). Должны быть РАЗНЫМИ.
TOPIC_IN=priv_weight_in
TOPIC_OUT=priv_weight_out

# Где лежат данные (база, состояние, журнал). По умолчанию — папка бота.
# Можно вынести, например, в /var/lib/weight-keeper, чтобы git pull не мешал данным.
DATA_DIR=
